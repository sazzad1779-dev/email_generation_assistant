# LLM Provider API Keys
GEMINI_API_KEY=
GROQ_API_KEY=

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000
HOST=0.0.0.0

# Generation Defaults
MAX_WORDS_DEFAULT=300
TEMPERATURE=0.0
TOP_P=0.95

# Provider Rate Limits
GEMINI_RPM=10
GEMINI_DAILY_LIMIT=1500
GROQ_RPM=30
GROQ_DAILY_LIMIT=1000

# Judge LLM Config
JUDGE_MODEL=gemini-2.5-flash
JUDGE_TEMPERATURE=0.0
JUDGE_RUNS=3
